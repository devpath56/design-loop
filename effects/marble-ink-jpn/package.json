{
  "name": "effect-marble-ink-jpn",
  "version": "1.0.0",
  "description": "Animated mesh-gradient effect — domain-warped fBm noise in one WebGL fragment shader, with a cursor-driven force field. No dependencies.",
  "keywords": [
    "webgl", "shader", "gradient", "mesh-gradient", "background",
    "animation", "glsl", "react", "web-component", "hero"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": ["./src/web-component.js"],
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./react": {
      "types": "./types/react.d.ts",
      "default": "./src/react/index.jsx"
    },
    "./web-component": {
      "default": "./src/web-component.js"
    },
    "./shader": {
      "default": "./src/shader.js"
    },
    "./presets": {
      "default": "./src/presets.js"
    }
  },
  "files": ["src", "types", "README.md", "LICENSE"],
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "engines": {
    "node": ">=18"
  }
}

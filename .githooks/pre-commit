#!/bin/sh
# design-loop learn-gate: a design surface may not change without a lesson.
#
# The failure this prevents: feedback comes in, a design surface changes, and no learning is
# logged because the change bypassed the loop. design-lessons.jsonl silently stops growing.
# This makes that impossible to commit silently.
#
# A DESIGN SURFACE is a prototype (.html not generated by the loop) or design.md. Tooling
# (checks/*.mjs) and generated views (workbench-*.html, design-*.html) do not count.
#
# Escape hatch, used honestly: git commit --no-verify, and say in the message why no lesson.
#
# Install:  cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

staged=$(git diff --cached --name-only)
surface=$(printf '%s\n' "$staged" | grep -E '\.html$|^design\.md$' | grep -vE '^(workbench-|design-|fixtures/)')
lesson=$(printf '%s\n' "$staged" | grep -cE '^design-lessons\.jsonl$')

if [ -n "$surface" ] && [ "$lesson" -eq 0 ]; then
  echo "COMMIT BLOCKED: a design surface changed but no lesson was logged."
  echo "  changed:"
  printf '    %s\n' $surface
  echo "  The loop's LEARN step did not run. Either:"
  echo "    - append one line to design-lessons.jsonl (what the feedback taught), or"
  echo "    - git commit --no-verify and state in the message why this needs no lesson."
  exit 1
fi
exit 0
